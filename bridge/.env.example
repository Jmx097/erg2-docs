NODE_ENV=production
PORT=8787
RELAY_BASE_URL=https://api.example.com
BRIDGE_STORE_DRIVER=postgres
DATABASE_URL=postgres://openclaw:openclaw@127.0.0.1:5432/openclaw
DATABASE_SCHEMA=openclaw_bridge
DATABASE_AUTO_MIGRATE=true
STARTUP_REQUIRE_READY=true
ADMIN_API_TOKEN=replace-with-an-operator-admin-token
TOKEN_HASH_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-ed25519-private-key\n-----END PRIVATE KEY-----"
ACCESS_TOKEN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-ed25519-public-key\n-----END PUBLIC KEY-----"
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=replace-with-openclaw-operator-token
G2_BRIDGE_TOKEN=replace-with-a-revocable-g2-bridge-token
OPENCLAW_MODEL=openclaw/default
OPENCLAW_REQUEST_TIMEOUT_MS=30000
OPENCLAW_HEALTH_CHECK=true
PAIRING_CODE_TTL_MS=600000
BOOTSTRAP_TOKEN_TTL_MS=60000
PAIRING_CODE_MAX_ATTEMPTS=10
ACCESS_TOKEN_TTL_MS=300000
REFRESH_TOKEN_SLIDING_TTL_MS=2592000000
REFRESH_TOKEN_ABSOLUTE_TTL_MS=7776000000
EVEN_HUB_REFRESH_TOKEN_SLIDING_TTL_MS=604800000
EVEN_HUB_REFRESH_TOKEN_ABSOLUTE_TTL_MS=2592000000
WS_TICKET_TTL_MS=30000
RELAY_HEARTBEAT_INTERVAL_MS=25000
RELAY_PONG_TIMEOUT_MS=10000
RELAY_STALE_MISS_COUNT=2
CLEANUP_INTERVAL_MS=60000
PROMPT_RESULT_RETENTION_MS=86400000
